{
  "name": "@it-all-service/eslint-plugin-itall-react",
  "version": "0.3.0",
  "description": "Team-specific React/Next.js lint rules consumed by @it-all-service/react-doctor",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "itall",
    "nextjs",
    "react"
  ],
  "homepage": "https://github.com/IT-ALL-Service/itall-react-doctor#readme",
  "bugs": {
    "url": "https://github.com/IT-ALL-Service/itall-react-doctor/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/IT-ALL-Service/itall-react-doctor.git",
    "directory": "packages/eslint-plugin-itall-react"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "vp pack --watch",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && NODE_ENV=production vp pack",
    "typecheck": "tsc --noEmit",
    "test": "vp test run"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  },
  "engines": {
    "node": ">=22"
  }
}
